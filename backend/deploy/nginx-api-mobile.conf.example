# Nginx: API Flutter (Node.js) tại path /mobile trên maclenin.io.vn
# VPS: 35.221.155.202
# DNS: maclenin.io.vn → A record → 35.221.155.202
#
# App Flutter gọi:
#   https://maclenin.io.vn/mobile/health
#   https://maclenin.io.vn/mobile/api/orders
#   https://maclenin.io.vn/mobile/api/payments/payos/webhook  (PayOS webhook)
#
# Docker flutter-api bind: 127.0.0.1:3001 → container :3000
# Copy block location /mobile/ vào server block HTTPS của maclenin.io.vn

server {
    listen 443 ssl http2;
    server_name maclenin.io.vn;

    # ssl_certificate /etc/letsencrypt/live/maclenin.io.vn/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/maclenin.io.vn/privkey.pem;

    # Bỏ prefix /mobile khi chuyển sang Node (Express route gốc: /health, /api/...)
    location /mobile/ {
        rewrite ^/mobile/?(.*)$ /$1 break;
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Socket.IO WebSocket upgrade (chat nhân viên real-time)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 120s;
    }

    # map $http_upgrade $connection_upgrade — thêm vào http { } block của nginx.conf:
    # map $http_upgrade $connection_upgrade {
    #     default upgrade;
    #     ''      close;
    # }

    # ... các location khác của site maclenin.io.vn (admin, static, ...)
}
