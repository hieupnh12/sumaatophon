# Nginx: Flutter API (Node.js) trên VPS maclenin.io.vn
# DNS: api-mobile.maclenin.io.vn → A record → 35.221.155.202
# Copy vào /etc/nginx/sites-available/ rồi enable + certbot.

server {
    listen 80;
    server_name api-mobile.maclenin.io.vn;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name api-mobile.maclenin.io.vn;

    # certbot sẽ tạo sau: certbot --nginx -d api-mobile.maclenin.io.vn
    # ssl_certificate /etc/letsencrypt/live/api-mobile.maclenin.io.vn/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api-mobile.maclenin.io.vn/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
