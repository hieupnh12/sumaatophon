# Nginx (host trên VPS): proxy Flutter Node API tại /mobile/
# VPS: maclenin.io.vn
#
# App Flutter gọi:
#   https://maclenin.io.vn/mobile/health          → {"ok":true}
#   https://maclenin.io.vn/mobile/products
#   https://maclenin.io.vn/mobile/api/orders
#   https://maclenin.io.vn/mobile/socket.io/        (Socket.IO chat)
#
# Backend Docker (backend/docker-compose.yml):
#   127.0.0.1:3001 → container :3000
#
# Kiểm tra sau deploy:
#   curl -s https://maclenin.io.vn/mobile/health
#   # Phải trả JSON, KHÔNG phải HTML React (FShop SPA).

# Thêm vào http { } block của nginx.conf (một lần):
# map $http_upgrade $connection_upgrade {
#     default upgrade;
#     ''      close;
# }

# Thêm vào server block HTTPS của maclenin.io.vn — TRƯỚC location / { try_files ... }:

    location ^~ /mobile/ {
        rewrite ^/mobile/?(.*)$ /$1 break;
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 120s;
        proxy_connect_timeout 60s;
        proxy_buffering off;
    }

# Nếu dùng Docker Compose nginx (backend/deploy/nginx-maclenin.docker.conf),
# service tên flutter-api thay cho 127.0.0.1:3001 — xem file đó.
