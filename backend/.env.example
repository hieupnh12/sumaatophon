# MySQL — DB server riêng (Aiven hoặc MySQL trên VPS khác)
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_password_here
DB_NAME=phoneShop

# Port bên trong container (docker-compose ghi đè = 3000, không cần đổi)
PORT=3000

# Chỉ dùng khi chạy docker compose trên VPS: port bind localhost cho Nginx proxy
# FLUTTER_API_PORT=3001

# PayOS — lấy từ https://my.payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# URL công khai của API trên VPS (Flutter productionBaseUrl)
PUBLIC_API_BASE_URL=https://maclenin.io.vn/mobile

# PayOS redirect — WebView app bắt path /payment/success và /payment/cancel
PAYOS_RETURN_URL=https://maclenin.io.vn/mobile/payment/success
PAYOS_CANCEL_URL=https://maclenin.io.vn/mobile/payment/cancel

# Đăng ký webhook trên dashboard PayOS:
# https://maclenin.io.vn/mobile/api/payments/payos/webhook

# Email xác nhận đơn hàng — chỉ cần 2 dòng (Gmail: dùng App Password)
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# Tùy chọn (bỏ qua được — tự suy từ @gmail.com → smtp.gmail.com:587, From = PhoneShop <MAIL_USERNAME>):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=PhoneShop <your@gmail.com>
